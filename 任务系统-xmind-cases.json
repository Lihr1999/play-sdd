        {"id": "TC-003", "title": "累计型进行中进度条", "priority": "P0", "precondition": "存在 cumulative 且 targetCount>1", "steps": ["玩法使进度为中间值"], "testData": "-", "expectedResult": "展示比例正确的进度条"},
